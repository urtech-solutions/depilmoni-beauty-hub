{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@depilmoni/domain": ["packages/domain/src/index.ts"],
      "@depilmoni/application": ["packages/application/src/index.ts"],
      "@depilmoni/infrastructure": ["packages/infrastructure/src/index.ts"],
      "@depilmoni/ui": ["packages/ui/src/index.ts"]
    }
  }
}
