{
  "name": "depilmoni-beauty-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "docker compose up -d postgres redis && turbo dev --filter=@depilmoni/web",
    "dev:all": "docker compose up -d postgres redis && turbo dev",
    "dev:web": "pnpm --filter @depilmoni/web dev",
    "dev:cms": "pnpm --filter @depilmoni/cms dev",
    "dev:commerce": "pnpm --filter @depilmoni/commerce dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test --filter=@depilmoni/core",
    "test:e2e": "pnpm --filter @depilmoni/web test:e2e",
    "seed:print": "pnpm --filter @depilmoni/core seed:print"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.20.6",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
