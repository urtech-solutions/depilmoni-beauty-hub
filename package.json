{
  "name": "depilmoni-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:infra && turbo run dev --parallel --filter=@depilmoni/web --filter=@depilmoni/cms",
    "dev:all": "pnpm dev:infra && turbo run dev --parallel --filter=@depilmoni/web --filter=@depilmoni/cms --filter=@depilmoni/commerce",
    "dev:infra": "docker-compose up -d",
    "dev:web": "pnpm dev:infra && turbo run dev --parallel --filter=@depilmoni/web",
    "dev:cms": "pnpm dev:infra && turbo run dev --parallel --filter=@depilmoni/cms",
    "dev:commerce": "pnpm dev:infra && turbo run dev --parallel --filter=@depilmoni/commerce",
    "stop": "docker-compose down",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=@depilmoni/core",
    "test:e2e": "pnpm --filter @depilmoni/web test:e2e",
    "seed:print": "pnpm --filter @depilmoni/core seed:print"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  }
}
